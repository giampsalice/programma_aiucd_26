<div id="aiucd-map-latest" class="aiucd-map-wrap">
  <style>
    #aiucd-map-latest { max-width: 1120px; margin: 0 auto; font-family: Arial, Helvetica, sans-serif; color:#222; }
    #aiucd-map-latest * { box-sizing: border-box; }
    #aiucd-map-latest .aiucd-title { margin:0 0 10px; font-size:24px; line-height:1.2; }
    #aiucd-map-latest .aiucd-note { margin:0 0 18px; font-size:14px; color:#555; }
    #aiucd-map-latest .aiucd-floor { margin:22px 0 38px; }
    #aiucd-map-latest .aiucd-floor h3 { margin:0 0 10px; font-size:20px; }
    #aiucd-map-latest .aiucd-image-box { position:relative; width:100%; border:1px solid #ddd; border-radius:14px; overflow:hidden; background:#fff; box-shadow:0 6px 22px rgba(0,0,0,.08); }
    #aiucd-map-latest .aiucd-image-box img { display:block; width:100%; height:auto; }
    #aiucd-map-latest .hotspot { position:absolute; display:block; padding:0; cursor:pointer; border:2px solid rgba(0,135,130,.90); background:rgba(0,135,130,.22); border-radius:4px; outline:0; transition:background .15s ease, box-shadow .15s ease, border-color .15s ease; }
    #aiucd-map-latest .hotspot:hover, #aiucd-map-latest .hotspot:focus, #aiucd-map-latest .hotspot.active { background:rgba(0,135,130,.36); border-color:rgba(0,120,115,1); box-shadow:0 0 0 4px rgba(0,135,130,.18); }
    #aiucd-map-latest .hotspot::after { content:""; position:absolute; left:50%; top:50%; width:14px; height:14px; transform:translate(-50%,-50%); border-radius:50%; background:rgba(255,255,255,.82); box-shadow:0 0 0 5px rgba(0,135,130,.28); }
    #aiucd-map-latest .tip { opacity:0; visibility:hidden; position:absolute; left:50%; top:-12px; transform:translate(-50%,-100%); min-width:190px; max-width:min(300px, 90vw); padding:12px 14px; background:rgba(17,17,17,.94); color:#fff; border-radius:12px; font-size:14px; line-height:1.35; text-align:center; box-shadow:0 12px 34px rgba(0,0,0,.30); z-index:30; pointer-events:none; transition:opacity .15s ease; }
    #aiucd-map-latest .tip::after { content:""; position:absolute; left:50%; bottom:-8px; transform:translateX(-50%); border-width:8px 8px 0 8px; border-style:solid; border-color:rgba(17,17,17,.94) transparent transparent transparent; }
    #aiucd-map-latest .tip strong { display:block; font-size:15px; margin-bottom:4px; }
    #aiucd-map-latest .hotspot:hover .tip, #aiucd-map-latest .hotspot:focus .tip, #aiucd-map-latest .hotspot.active .tip { opacity:1; visibility:visible; }
    #aiucd-map-latest .legend { display:flex; flex-wrap:wrap; gap:8px; margin:12px 0 0; }
    #aiucd-map-latest .legend button { border:1px solid #ddd; background:#fff; padding:8px 10px; border-radius:999px; cursor:pointer; font-size:13px; }
    #aiucd-map-latest .legend button:hover, #aiucd-map-latest .legend button:focus { border-color:#008b8b; outline:none; }
    @media (max-width:700px) {
      #aiucd-map-latest .tip { font-size:12px; min-width:150px; max-width:220px; padding:9px 10px; }
      #aiucd-map-latest .hotspot { border-width:2px; }
      #aiucd-map-latest .hotspot::after { width:10px; height:10px; }
    }
  </style>

